# ── Hermes-on-Blaxel - config template ─────────────────────────────────────────
# Copy this to `.env` and fill it in, OR just run:  ./scripts/setup.sh  (the wizard
# generates the random secrets, computes the webhook URL, and deploys for you).
# Never commit your real .env - it holds live secrets.

# --- Deployment mode ---  always-on (24/7, instant) | scale-to-zero (sleeps when idle, cheap)
DEPLOY_MODE=always-on

# --- Model (provider-agnostic) ---  pick any provider Hermes supports
MODEL_PROVIDER=zai           # zai | anthropic | openai | gemini | kimi-coding | minimax | ...
MODEL_NAME=glm-5.1           # model id for that provider
MODEL_BASE_URL=              # optional endpoint override (e.g. https://api.z.ai/api/coding/paas/v4)
# Your provider's API key under ITS standard env var name (wizard sets the right one):
ZAI_API_KEY=                 # or ANTHROPIC_API_KEY= / OPENAI_API_KEY= / GEMINI_API_KEY= / KIMI_API_KEY=
# (bring-your-own: leave the model lines blank and pick a provider in the dashboard /
#  `hermes setup model` after deploy.)

# --- Messaging platform ---  pick ONE. Telegram uses an inbound webhook (needs the
#     BLAXEL_TELEGRAM_PREVIEW below); Discord connects outbound (no webhook/preview).
#     Leave both blank to configure later via the dashboard / `hermes gateway setup`.

# Telegram (token from @BotFather; your numeric id from @userinfobot):
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # your Telegram user id (only this user may chat)
TELEGRAM_HOME_CHANNEL=           # usually same as above (where cron/proactive msgs go)
TELEGRAM_WEBHOOK_PORT=9099       # internal port (do not change; 8443 is NOT routable)
# Auto-filled by the wizard after the preview exists. Leave blank for a fresh setup.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=         # auto-generated by the wizard (random hex)

# Discord (token from the Discord Developer Portal -> Bot; id via Developer Mode -> Copy User ID):
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=           # your Discord user id (only this user may chat)

# --- Web dashboard (optional) ---  leave USERNAME blank to disable the dashboard
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=     # e.g. your name → enables username/password login
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=     # auto-generated by the wizard if blank
HERMES_DASHBOARD_BASIC_AUTH_SECRET=       # auto-generated (signs login sessions)
HERMES_DASHBOARD_SESSION_TOKEN=           # auto-generated (also the dashboard on/off switch)

# --- Blaxel resource names (infra) ---
BLAXEL_SANDBOX_NAME=hermes-box
BLAXEL_TELEGRAM_PREVIEW=hermes-box-tg   # only created for Telegram (Discord needs no preview)
BLAXEL_DASHBOARD_PREVIEW=hermes-box-dash
